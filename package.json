{
  "name": "openfl-flight",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "!packages/upstream"
  ],
  "scripts": {
    "assets": "npm run assets:displayingabitmap",
    "assets:displayingabitmap": "cd examples/displayingabitmap && tsx ../../packages/upstream/scripts/download-assets.ts",
    "build": "npm run build:upstream",
    "build:upstream": "npm --prefix packages/upstream install && npm --prefix packages/upstream run build",
    "sync": "git submodule update --remote --merge",
    "generate": "node packages/ts-processing/generate.js"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "vite": "^8.0.2"
  }
}
